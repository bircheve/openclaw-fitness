# Bridge server port (default: 18792)
PORT=18792

# OpenClaw binary path (default: "openclaw" — uses PATH)
# OPENCLAW_BIN=/opt/homebrew/bin/openclaw

# Notification channel — the OpenClaw channel adapter to deliver through
# Examples: bluebubbles, telegram, slack
# NOTIFY_CHANNEL=bluebubbles

# Notification target — phone number or chat ID for the notification channel
# Examples: +15551234567, @username
# NOTIFY_TARGET=+15551234567
